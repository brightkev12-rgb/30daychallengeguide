    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# importing data\n",
        "\n",
        "physical_activity = pd.read_csv(\"physical_activity.csv\")"
      ],
      "id": "8c7fa1c6",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# data cleaning\n",
        "\n",
        "physical_activity.isnull().sum()\n",
        "\n",
        "\n",
        "\n",
        "physical_activity= physical_activity.dropna()\n",
        "\n",
        "physical_activity\n",
        "\n",
        "\n",
        "\n",
        "physical_activity.isnull().values.any()\n",
        "\n",
        "\n",
        "\n",
        "# renaming column\n",
        "\n",
        "physical_activity=physical_activity.rename(columns={\"oms_recommendation\":\"who_recommendation\"})\n",
        "\n",
        "physical_activity\n",
        "\n",
        "\n",
        "\n",
        "physical_activity.info\n",
        "\n",
        "\n",
        "\n",
        "physical_activity[\"bmi\"] = pd.to_numeric(physical_activity[\"bmi\"], errors=\"coerce\")\n",
        "\n",
        "physical_activity[\"sedentary_ap_s_day\"] = pd.to_numeric(physical_activity[\"sedentary_ap_s_day\"], errors=\"coerce\")\n",
        "\n",
        "physical_activity[\"light_ap_s_day\"] = pd.to_numeric(physical_activity[\"light_ap_s_day\"], errors=\"coerce\")\n",
        "\n",
        "physical_activity[\"mvpa_s_day\"] = pd.to_numeric(physical_activity[\"mvpa_s_day\"], errors=\"coerce\")\n",
        "\n",
        "physical_activity\n",
        "\n",
        "\n",
        "\n",
        "# renaming rows\n",
        "\n",
        "physical_activity[\"status\"]=physical_activity[\"status\"].replace({\"Adulte\": \"Adult\", \"Enfant\":\"Infant\"})"
      ],
      "id": "28405f05",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# data summary\n",
        "\n",
        "physical_activity[\"mvpa_min_day\"]=physical_activity[\"mvpa_s_day\"]/60\n",
        "\n",
        "physical_activity\n",
        "\n",
        "\n",
        "\n",
        "physical_activity[\"sedentary_min_day\"]= physical_activity[\"sedentary_ap_s_day\"]/60\n",
        "\n",
        "physical_activity\n",
        "\n",
        "\n",
        "\n",
        "physical_activity[\"light_min_day\"]= physical_activity[\"light_ap_s_day\"]/60"
      ],
      "id": "1d031d6f",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "physical_activity=physical_activity.drop(columns={\"sedentary_ap_s_day\", \"light_ap_s_day\", \"mvpa_s_day\"})"
      ],
      "id": "e79ef304",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "physical_activity_avg=physical_activity.groupby([\"sex\", \"status\", \"who_recommendation\"]).agg(\n",
        "\n",
        "    avg_bmi=(\"bmi\", \"mean\"),\n",
        "\n",
        "    avg_mvpa_min_day=(\"mvpa_min_day\", \"mean\"),\n",
        "\n",
        "    avg_sedentary_min_day=(\"sedentary_min_day\", \"mean\")\n",
        "\n",
        ").reset_index()"
      ],
      "id": "ee591038",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# % meeting WHO recommendations by sex \n",
        "\n",
        "who_by_sex = (\n",
        "\n",
        "    physical_activity\n",
        "\n",
        "    .groupby([\"sex\", \"who_recommendation\"])\n",
        "\n",
        "    .size()\n",
        "\n",
        "    .reset_index(name=\"count\")\n",
        "\n",
        ")\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "who_by_sex[\"percentage\"] = (\n",
        "\n",
        "    who_by_sex.groupby(\"sex\")[\"count\"]\n",
        "\n",
        "    .transform(lambda x: x / x.sum() * 100)\n",
        "\n",
        ")\n"
      ],
      "id": "4c180457",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#% meeting WHO recommendations by age group\n",
        "\n",
        "who_by_age= (\n",
        "\n",
        "    physical_activity\n",
        "\n",
        "    .groupby([\"status\", \"who_recommendation\"])\n",
        "\n",
        "    .size()\n",
        "\n",
        "    .reset_index(name=\"count\")\n",
        "\n",
        ")\n",
        "\n",
        "who_by_age[\"percentage\"] = (\n",
        "\n",
        "    who_by_age.groupby(\"status\")[\"count\"]\n",
        "\n",
        "    .transform(lambda x: x / x.sum() * 100)\n",
        "\n",
        ")"
      ],
      "id": "a2f0448f",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Average MVPA (minutes/day) by age group and sex\n",
        "\n",
        "bar_chart=px.bar(physical_activity_avg, x=\"status\", y=\"avg_mvpa_min_day\", color=\"sex\", title=\"Average MVPA (minutes/day) by age group and sex\")"
      ],
      "id": "0c58761e",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "stack_bar=px.bar(who_by_age, x=\"status\", y=\"percentage\", color=\"who_recommendation\", title=\"WHO Recommendations by Age Group\")\n",
        "\n",
        "\n",
        "\n",
        "stack_bar.update_layout(barmode=\"stack\")"
      ],
      "id": "43cab1cc",
      "execution_count": null,
      "outputs": []
    },
    {
